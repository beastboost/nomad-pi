# Nomad Pi Environment Configuration
# Copy this file to .env and modify as needed

# OMDb API Key for movie/show metadata fetching
# Get a free key at https://www.omdbapi.com/apikey.aspx
# OMDB_API_KEY=your_api_key_here

# Admin password (set during first setup)
# If not set, a default password is generated and printed to console
# ADMIN_PASSWORD=your_secure_password

# Pre-hashed admin password (bcrypt hash, alternative to plaintext)
# ADMIN_PASSWORD_HASH=$2b$12$...

# Allow insecure default password on first setup (default: true)
# Set to false in production to force setting a password via env
# ALLOW_INSECURE_DEFAULT=true

# CORS allowed origins (comma-separated)
# Default: * (all origins)
# ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.100:8000

# Session expiry in days (default: 30)
# SESSION_MAX_AGE_DAYS=30

# OpenSubtitles API key for subtitle search/download
# Get a key at https://www.opensubtitles.com/en/consumers
# OPENSUBTITLES_KEY=your_api_key_here

# Log file location (default: data/app.log)
# NOMAD_LOG_FILE=data/app.log

# Server port (default: 8000)
# PORT=8000
