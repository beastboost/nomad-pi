<Window x:Class="NomadTransferTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NomadTransferTool"
        Title="Nomad Media Transfer Tool" Height="800" Width="1300"
        Background="#0D0D0D" Foreground="White"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="DangerColor" Color="#f44336"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
        <local:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <local:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <local:BooleanToColorConverter x:Key="BooleanToColorConverter"/>
        <local:CategoryToVisibilityConverter x:Key="CategoryToVis"/>
        <local:IsVideoToVisibilityConverter x:Key="IsVideoToVis"/>
        <local:VideoTranscodeVisibilityConverter x:Key="VideoTranscodeVis"/>
        <local:LongToVisibilityConverter x:Key="LongToVisibilityConverter"/>
        
        <!-- Modern Colors -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#FF4081"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#4caf50"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#0D0D0D"/>
        <SolidColorBrush x:Key="SidebarColor" Color="#161616"/>
        <SolidColorBrush x:Key="CardColor" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BorderColor" Color="#303030"/>
        <SolidColorBrush x:Key="TextColor" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="MutedTextColor" Color="#B0B0B0"/>
        <SolidColorBrush x:Key="InputBackground" Color="#252525"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="FontFamily" Value="Segoe UI, Roboto, sans-serif"/>
        </Style>

        <Style x:Key="HeaderBlock" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <!-- Sidebar Tab Style -->
        <Style x:Key="SidebarTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextColor}"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="4,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0,8,8,0" Margin="0,2,10,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#202020"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3D3D3D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4D4D4D"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F50057"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C51162"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBackground}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" 
                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                        Background="{TemplateBinding Background}" 
                                        Foreground="{TemplateBinding Foreground}"
                                        Grid.Column="2" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" Focusable="false" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" CornerRadius="4" BorderThickness="1" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}">
                                            <Path x:Name="Arrow" Fill="White" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Data="M0,0 L4,4 L8,0 Z"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False"  Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="10,3,30,3" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True"  Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#2D2D2D" BorderThickness="1" BorderBrush="{StaticResource BorderColor}" CornerRadius="0,0,4,4"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryColor}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#444444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation -->
        <Border Grid.Column="0" Background="{StaticResource SidebarColor}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,25,20,30">
                    <TextBlock Text="Nomad" FontSize="32" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                    <TextBlock Text="Transfer Tool" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource MutedTextColor}" Margin="2,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <RadioButton x:Name="TabTransfer" Style="{StaticResource SidebarTabStyle}" Content="🚀  Transfer Hub" IsChecked="True"/>
                    <RadioButton x:Name="TabDebrid" Style="{StaticResource SidebarTabStyle}" Content="🎬  Debrid Manager"/>
                    <RadioButton x:Name="TabFileManager" Style="{StaticResource SidebarTabStyle}" Content="📁  File Manager"/>
                    <RadioButton x:Name="TabSettings" Style="{StaticResource SidebarTabStyle}" Content="⚙️  Settings"/>
                </StackPanel>

                <!-- Server Status Indicator -->
                <Border Grid.Row="2" Background="{StaticResource CardColor}" Margin="10,10,10,20" CornerRadius="8" Padding="15,12" BorderThickness="1" BorderBrush="{StaticResource BorderColor}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="12" Height="12" Fill="{Binding ServerStatusColor}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding ServerStatus}" FontWeight="Bold" FontSize="13" Foreground="{Binding ServerStatusColor}"/>
                            <TextBlock Text="{Binding ServerIp}" FontSize="11" Foreground="{StaticResource MutedTextColor}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            
            <!-- ========================================== -->
            <!-- TAB 1: TRANSFER HUB                        -->
            <!-- ========================================== -->
            <Grid Visibility="{Binding IsChecked, ElementName=TabTransfer, Converter={StaticResource BoolToVis}}" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Drives -->
                    <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Connected Drives" Style="{StaticResource HeaderBlock}"/>
                            
                            <ListBox Grid.Row="1" x:Name="DriveList" ItemsSource="{Binding Drives}" Margin="0,0,0,10" SelectionChanged="DriveList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="5,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="💾" FontSize="20" VerticalAlignment="Top" Margin="0,2,10,0"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Label}" FontWeight="Bold" FontSize="13" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Name}" FontSize="10" Foreground="{StaticResource MutedTextColor}" TextWrapping="Wrap"/>
                                                    
                                                    <StackPanel Visibility="{Binding TotalSize, Converter={StaticResource LongToVisibilityConverter}}">
                                                        <ProgressBar Value="{Binding PercentUsed, Mode=OneWay}" Height="4" Margin="0,5" Background="#333" Foreground="{StaticResource PrimaryColor}" BorderThickness="0"/>
                                                        <TextBlock Text="{Binding SizeDisplay}" FontSize="11" Margin="0,0,0,2"/>
                                                    </StackPanel>
                                                    
                                                    <TextBlock Text="{Binding StatusDisplay}" FontSize="11" FontWeight="Bold" Margin="0,2,0,0"
                                                            Foreground="{Binding IsMounted, Converter={StaticResource BooleanToColorConverter}}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel Grid.Row="2">
                                <UniformGrid Columns="2">
                                    <Button Content="Prepare Folders" Click="PrepareDrive_Click" Margin="0,0,5,0" FontSize="11"/>
                                    <Button Content="Format (exFAT)" Click="FormatDrive_Click" Background="#d32f2f" Margin="5,0,0,0" FontSize="11"/>
                                </UniformGrid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Right: Drop Zone & Queue -->
                    <Grid Grid.Column="1" Margin="10,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Drop Zone (Only visible when empty) -->
                        <Border Grid.Row="1" Style="{StaticResource CardBorder}" x:Name="DropZone" AllowDrop="True" 
                                Drop="Transfer_Drop" DragOver="DropZone_DragOver" Background="{StaticResource InputBackground}" 
                                BorderThickness="2" BorderBrush="{StaticResource PrimaryColor}"
                                Visibility="{Binding ReviewQueue.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=0}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="📁" FontSize="64" HorizontalAlignment="Center" Opacity="0.5"/>
                                <TextBlock Text="Drop Media Files Here" FontSize="20" FontWeight="Bold" Margin="0,10,0,5" Opacity="0.8"/>
                                <TextBlock Text="Movies, TV Shows, Music, Books, or Photos" FontSize="12" Opacity="0.6" HorizontalAlignment="Center"/>
                                <UniformGrid Columns="2" Margin="0,20,0,0" Width="200">
                                    <Button Content="Select Files" Click="SelectFiles_Click" Margin="0,0,5,0"/>
                                    <Button Content="Select Folder" Click="SelectFolder_Click" Margin="5,0,0,0"/>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- Review Queue (Visible when items exist) -->
                        <Border Grid.Row="1" Style="{StaticResource CardBorder}" AllowDrop="True" Drop="Transfer_Drop" DragOver="DropZone_DragOver"
                                Visibility="{Binding ReviewQueue.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=1}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Review Media" Style="{StaticResource HeaderBlock}" Margin="0"/>
                                    
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                                        <TextBlock Text="Bulk:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11" Foreground="{StaticResource MutedTextColor}"/>
                                        <ComboBox x:Name="BulkCategoryCombo" Width="80" Height="24" FontSize="11">
                                            <ComboBoxItem Content="movies" Tag="movies" IsSelected="True"/>
                                            <ComboBoxItem Content="shows" Tag="shows"/>
                                            <ComboBoxItem Content="music" Tag="music"/>
                                            <ComboBoxItem Content="books" Tag="books"/>
                                            <ComboBoxItem Content="gallery" Tag="gallery"/>
                                            <ComboBoxItem Content="files" Tag="files"/>
                                        </ComboBox>
                                        <Button Content="Set" Click="ApplyBulkCategory_Click" Padding="8,2" Margin="4,0" FontSize="11" Height="24"/>
                                        <Button Content="Clean" Click="BulkCleanTitles_Click" Padding="8,2" FontSize="11" Height="24" Background="#3D3D3D" ToolTip="Clean selected titles"/>
                                    </StackPanel>

                                    <Button Grid.Column="2" Content="Clear All" Click="ClearReviewQueue_Click" 
                                            Background="Transparent" BorderThickness="0" Foreground="{StaticResource DangerColor}" 
                                            VerticalAlignment="Center" Cursor="Hand"/>
                                </Grid>
                                
                                <ListBox Grid.Row="1" ItemsSource="{Binding ReviewQueue}" x:Name="ReviewListBox" SelectionMode="Extended">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#252525" CornerRadius="6" Margin="0,0,0,8" Padding="12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="40"/>
                                                        <ColumnDefinition Width="40"/>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="⚠️" Foreground="#FFC107" VerticalAlignment="Center" Margin="0,0,10,0" 
                                                            Visibility="{Binding IsDuplicate, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                            ToolTip="This file already exists on the target drive and will be overwritten."/>
                                                    
                                                    <StackPanel Grid.Column="1" Margin="0,0,15,0" VerticalAlignment="Center">
                                                        <TextBlock Text="Title" FontSize="10" Foreground="{StaticResource MutedTextColor}" Margin="0,0,0,2"/>
                                                        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="White" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderColor}" Padding="0,2"/>
                                                        
                                                        <Grid Margin="0,6,0,0" Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}">
                                                            <ProgressBar Value="{Binding Progress}" Height="4" Background="#333" Foreground="{StaticResource PrimaryColor}" BorderThickness="0"/>
                                                            <TextBlock Text="{Binding StatusMessage}" FontSize="9" Foreground="White" HorizontalAlignment="Right" Margin="0,-12,0,0"/>
                                                        </Grid>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" Margin="0,0,10,0" VerticalAlignment="Center">
                                                        <TextBlock Text="Year" FontSize="10" Foreground="{StaticResource MutedTextColor}" Margin="0,0,0,2"/>
                                                        <TextBox Text="{Binding Year, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="White" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderColor}" Padding="0,2"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="3" Margin="0,0,5,0" VerticalAlignment="Center" Visibility="{Binding Category, Converter={StaticResource CategoryToVis}, ConverterParameter=shows}">
                                                        <TextBlock Text="S" FontSize="10" Foreground="{StaticResource MutedTextColor}" Margin="0,0,0,2"/>
                                                        <TextBox Text="{Binding Season, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="White" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderColor}" Padding="0,2"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="4" Margin="0,0,10,0" VerticalAlignment="Center" Visibility="{Binding Category, Converter={StaticResource CategoryToVis}, ConverterParameter=shows}">
                                                        <TextBlock Text="E" FontSize="10" Foreground="{StaticResource MutedTextColor}" Margin="0,0,0,2"/>
                                                        <TextBox Text="{Binding Episode, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="White" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderColor}" Padding="0,2"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="5" Margin="0,0,15,0" VerticalAlignment="Center">
                                                        <TextBlock Text="Category" FontSize="10" Foreground="{StaticResource MutedTextColor}" Margin="0,0,0,2"/>
                                                        <ComboBox SelectedValue="{Binding Category}" SelectedValuePath="Tag" Background="Transparent" Foreground="White" BorderThickness="0" Height="22" Padding="2,0">
                                                            <ComboBoxItem Content="movies" Tag="movies"/>
                                                            <ComboBoxItem Content="shows" Tag="shows"/>
                                                            <ComboBoxItem Content="music" Tag="music"/>
                                                            <ComboBoxItem Content="books" Tag="books"/>
                                                            <ComboBoxItem Content="gallery" Tag="gallery"/>
                                                            <ComboBoxItem Content="files" Tag="files"/>
                                                        </ComboBox>
                                                    </StackPanel>

                                                    <Button Grid.Column="6" Content="✕" Click="RemoveFromQueue_Click" 
                                                            Background="Transparent" Foreground="#888" FontSize="14" FontWeight="Bold" 
                                                            VerticalAlignment="Center" HorizontalAlignment="Center" Cursor="Hand" Padding="5"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                        <!-- Action Bar -->
                        <Border Grid.Row="2" Background="#111" CornerRadius="6" Padding="15" Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SpaceWarning}" Foreground="{StaticResource PrimaryColor}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding TranscodeQueue.Count, StringFormat='Transcode Queue: {0} items pending'}" Foreground="{StaticResource MutedTextColor}" FontSize="11" Margin="0,4,0,0" Visibility="{Binding TranscodeQueue.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=0}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Grid.Column="1">
                                            <Button Content="STOP" Click="StopProcessing_Click" Background="{StaticResource DangerColor}" Width="80" Height="36" Margin="0,0,10,0"
                                                    Visibility="{Binding IsTransferring, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            <Button Content="START TRANSFER" Click="StartProcessing_Click" Style="{StaticResource PrimaryButton}" Width="160" Height="36"
                                                    IsEnabled="{Binding IsTransferring, Converter={StaticResource InverseBooleanConverter}}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Global Transfer Progress Bar (Bottom) -->
                <Border Grid.Row="1" Background="{StaticResource CardColor}" CornerRadius="8" Padding="15" Margin="0,15,0,0"
                        Visibility="{Binding IsTransferring, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Status:" FontWeight="SemiBold" Margin="0,0,10,0" Foreground="{StaticResource PrimaryColor}"/>
                                <TextBlock x:Name="StatusText" Text="{Binding CurrentStatus}" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBlock x:Name="SpeedText" Text="{Binding TransferSpeed}" HorizontalAlignment="Right" Foreground="{StaticResource SecondaryColor}" FontWeight="SemiBold"/>
                        </Grid>

                        <StackPanel Grid.Row="1" Margin="0,5">
                            <ProgressBar x:Name="FileProgressBar" Height="6" Value="{Binding CurrentFileProgress}" 
                                         Background="#1A1A1A" Foreground="{StaticResource SecondaryColor}" BorderThickness="0" Margin="0,0,0,4"/>
                            <ProgressBar x:Name="MainProgress" Height="14" Value="{Binding TotalProgress}" 
                                         Background="#1A1A1A" Foreground="{StaticResource PrimaryColor}" BorderThickness="0"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2" x:Name="FileProgressText" Text="{Binding FileProgress}" FontSize="11" Foreground="{StaticResource MutedTextColor}" Margin="0,4,0,0"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ========================================== -->
            <!-- TAB 2: DEBRID MANAGER                      -->
            <!-- ========================================== -->
            <Grid Visibility="{Binding IsChecked, ElementName=TabDebrid, Converter={StaticResource BoolToVis}}" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search Header -->
                <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ComboBox SelectedValue="{Binding DebridSearchType}" SelectedValuePath="Tag" Width="100" Height="36" FontSize="14" Margin="0,0,10,0">
                                <ComboBoxItem Content="Movies" Tag="movie"/>
                                <ComboBoxItem Content="TV Shows" Tag="series"/>
                            </ComboBox>
                            
                            <StackPanel Orientation="Horizontal" Visibility="{Binding DebridSearchType, Converter={StaticResource CategoryToVis}, ConverterParameter=series}" Margin="0,0,15,0">
                                <TextBlock Text="S" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,5,0"/>
                                <TextBox Text="{Binding DebridSearchSeason, UpdateSourceTrigger=PropertyChanged}" Width="40" Height="36" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Background="{StaticResource InputBackground}" Foreground="White" BorderThickness="0"/>
                                <TextBlock Text="E" VerticalAlignment="Center" FontWeight="Bold" Margin="10,0,5,0"/>
                                <TextBox Text="{Binding DebridSearchEpisode, UpdateSourceTrigger=PropertyChanged}" Width="40" Height="36" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Background="{StaticResource InputBackground}" Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBox Grid.Column="1" Text="{Binding DebridTitleQuery, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="{StaticResource InputBackground}" Foreground="White" BorderThickness="0" 
                                 Height="36" FontSize="14" Padding="10,0" Margin="0,0,10,0" VerticalContentAlignment="Center"
                                 x:Name="DebridSearchBox"/>
                                 
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <ComboBox ItemsSource="{Binding DebridProviders}" SelectedItem="{Binding SelectedDebridProvider}" DisplayMemberPath="Name" Height="36" Width="120" Margin="0,0,10,0"/>
                            <Button Content="Search Cinemeta" Click="DebridSearchTitles_Click" Height="36" Padding="20,0" Style="{StaticResource PrimaryButton}" FontSize="14"/>
                        </StackPanel>

                        <Grid Grid.Row="1" Grid.ColumnSpan="3" Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Selected Provider Key" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{StaticResource MutedTextColor}"/>
                            <TextBox Grid.Column="1" Text="{Binding DebridApiKey, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource InputBackground}" Foreground="White" BorderThickness="0" Height="34" Padding="10,0" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                            <Button Grid.Column="2" Content="Save Key" Click="DebridSaveKey_Click" Height="34" Padding="15,0" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="3" Text="{Binding SelectedDebridKeyStatus}" VerticalAlignment="Center" Foreground="{StaticResource MutedTextColor}" TextWrapping="Wrap"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Results Area -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cinemeta Title Results -->
                    <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Select a Title" Style="{StaticResource HeaderBlock}"/>
                            
                            <ListBox Grid.Row="1" ItemsSource="{Binding DebridTitleResults}" SelectedItem="{Binding SelectedDebridTitle}" Background="Transparent">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel IsItemsHost="True"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="130" Margin="5" Background="#252525" CornerRadius="8" ClipToBounds="True">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="195"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <!-- We use a Rectangle with ImageBrush to handle missing posters gracefully -->
                                                <Rectangle Grid.Row="0" Fill="#1A1A1A"/>
                                                <Image Grid.Row="0" Source="{Binding Poster}" Stretch="UniformToFill"/>
                                                
                                                <Border Grid.Row="1" Padding="8">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="12" TextWrapping="Wrap" MaxHeight="34" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Year}" FontSize="11" Foreground="{StaticResource PrimaryColor}" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- Torrent Results -->
                    <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="10,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Available Torrents" Style="{StaticResource HeaderBlock}" Margin="0"/>
                                <Button Grid.Column="1" Content="Load Torrents" Click="DebridLoadTorrents_Click" Padding="10,4"/>
                            </Grid>

                            <ListBox Grid.Row="1" ItemsSource="{Binding DebridTorrentResults}" SelectedItem="{Binding SelectedDebridTorrent}" Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#252525" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding Meta}" Foreground="{StaticResource SecondaryColor}" FontSize="11"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel Grid.Row="2" Margin="0,15,0,0">
                                <Button Content="Download via Debrid &amp; Add to Queue" Click="DebridDownloadSelected_Click" Style="{StaticResource PrimaryButton}" Height="40" FontSize="14"/>
                                <TextBlock Text="{Binding DebridStatus}" Foreground="{StaticResource MutedTextColor}" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- ========================================== -->
            <!-- TAB 3: FILE MANAGER                        -->
            <!-- ========================================== -->
            <Grid Visibility="{Binding IsChecked, ElementName=TabFileManager, Converter={StaticResource BoolToVis}}" Margin="20">
                <Border Style="{StaticResource CardBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Remote File Manager" Style="{StaticResource HeaderBlock}"/>
                            <Button Grid.Column="1" Content="Refresh" Click="FileManagerRefresh_Click" Padding="15,4" FontSize="12"/>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,8,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="⬆ Up" Click="FileManagerUp_Click" Padding="15,4" FontSize="12" Margin="0,0,10,0"/>
                            <TextBox Grid.Column="1" Text="{Binding FileManagerPath, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource InputBackground}" Foreground="White" BorderThickness="0" Padding="10,6" FontSize="14" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="2" Content="Go" Click="FileManagerOpen_Click" Padding="15,4" FontSize="12" Margin="10,0,0,0" Style="{StaticResource PrimaryButton}"/>
                            <Button Grid.Column="3" Content="Root" Click="FileManagerRoot_Click" Padding="15,4" FontSize="12" Margin="10,0,0,0"/>
                        </Grid>

                        <ListView Grid.Row="2" x:Name="FileManagerList" ItemsSource="{Binding FileManagerItems}" Background="#111" BorderThickness="0" SelectionMode="Extended" MouseDoubleClick="FileManagerList_DoubleClick" Foreground="White">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="400"/>
                                    <GridViewColumn Header="Type" DisplayMemberBinding="{Binding Type}" Width="100"/>
                                    <GridViewColumn Header="Size" DisplayMemberBinding="{Binding SizeDisplay}" Width="100"/>
                                    <GridViewColumn Header="Modified" DisplayMemberBinding="{Binding ModifiedDisplay}" Width="150"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <Grid Grid.Row="3" Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding FileManagerStatus}" FontSize="12" Foreground="{StaticResource MutedTextColor}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Rename Selected" Click="RenameSelected_Click" Background="{StaticResource SecondaryColor}" Padding="15,6" FontSize="12" Margin="10,0,0,0"
                                    IsEnabled="{Binding IsTransferring, Converter={StaticResource InverseBooleanConverter}}"/>
                            <Button Grid.Column="2" Content="Delete Selected" Click="DeleteSelected_Click" Background="{StaticResource DangerColor}" Padding="15,6" FontSize="12" Margin="10,0,0,0"
                                    IsEnabled="{Binding IsTransferring, Converter={StaticResource InverseBooleanConverter}}"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ========================================== -->
            <!-- TAB 4: SETTINGS                            -->
            <!-- ========================================== -->
            <Grid Visibility="{Binding IsChecked, ElementName=TabSettings, Converter={StaticResource BoolToVis}}" Margin="20">
                <ScrollViewer>
                    <StackPanel MaxWidth="800" HorizontalAlignment="Left">
                        
                        <!-- Connection Settings -->
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Nomad Pi Connection" Style="{StaticResource HeaderBlock}"/>
                                
                                <Grid Margin="0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="IP Address or Hostname" VerticalAlignment="Center" Foreground="{StaticResource MutedTextColor}"/>
                                    <TextBox Grid.Column="1" Text="{Binding ServerIp, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource InputBackground}" Foreground="White" BorderThickness="0" Padding="8"/>
                                </Grid>
                                
                                <Grid Margin="0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Login Credentials" VerticalAlignment="Center" Foreground="{StaticResource MutedTextColor}"/>
                                    <TextBox Grid.Column="1" Text="{Binding ServerUsername, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource InputBackground}" Foreground="White" BorderThickness="0" Padding="8" Margin="0,0,10,0" Tag="Username"/>
                                    <PasswordBox Grid.Column="2" x:Name="NomadPassBox" Background="{StaticResource InputBackground}" Foreground="White" BorderThickness="0" Padding="8" PasswordChanged="NomadPassBox_PasswordChanged"/>
                                </Grid>
                                
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding AuthStatus}" VerticalAlignment="Center" Foreground="{StaticResource SecondaryColor}"/>
                                    <Button Grid.Column="1" Content="Authenticate" Click="Login_Click" Style="{StaticResource PrimaryButton}" Padding="20,6"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Samba Settings -->
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,15">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Samba / Network Share" Style="{StaticResource HeaderBlock}" Margin="0"/>
                                    <Button Grid.Column="1" Content="Auto-Sync from Pi" Click="SyncSamba_Click" Padding="15,4"/>
                                </Grid>
                                
                                <CheckBox Content="Enable Samba Transfer (Faster than API)" IsChecked="{Binding UseSamba}" FontSize="14" Margin="0,0,0,15"/>
                                
                                <Grid Margin="0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Share Path (UNC)" VerticalAlignment="Center" Foreground="{StaticResource MutedTextColor}"/>
                                    <TextBox Grid.Column="1" Text="{Binding SambaPath, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource InputBackground}" Foreground="White" BorderThickness="0" Padding="8"/>
                                </Grid>

                                <Grid Margin="0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Credentials" VerticalAlignment="Center" Foreground="{StaticResource MutedTextColor}"/>
                                    <TextBox Grid.Column="1" Text="{Binding SambaUser, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource InputBackground}" Foreground="White" BorderThickness="0" Padding="8" Margin="0,0,10,0"/>
                                    <PasswordBox Grid.Column="2" x:Name="SambaPassBox" Background="{StaticResource InputBackground}" Foreground="White" BorderThickness="0" Padding="8" PasswordChanged="SambaPassBox_PasswordChanged"/>
                                </Grid>

                                <Button Content="Test Connection" Click="TestSamba_Click" HorizontalAlignment="Right" Padding="20,6" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Processing & Transcoding -->
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Processing &amp; Transcoding" Style="{StaticResource HeaderBlock}"/>
                                
                                <Grid Margin="0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Global Target Quality" VerticalAlignment="Center" Foreground="{StaticResource MutedTextColor}"/>
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding EncodingPresets}" SelectedItem="{Binding SelectedGlobalPreset}" DisplayMemberPath="Name" Height="32"/>
                                </Grid>

                                <CheckBox x:Name="HandbrakeCheck" Content="Enable Video Transcoding (Handbrake)" IsEnabled="{Binding IsHandbrakeAvailable}" IsChecked="{Binding IsTranscodingEnabled}" Margin="0,10"/>
                                <CheckBox x:Name="AutoMoveCheck" Content="Auto-Move to target drive when finished" IsChecked="True" Margin="0,10"/>
                                <CheckBox Content="Delete source files after successful transfer" IsChecked="{Binding DeleteSourceAfterTransfer}" Foreground="{StaticResource DangerColor}" Margin="0,10"/>

                                <Border Background="#252525" CornerRadius="6" Padding="15" Margin="0,15,0,0" Visibility="{Binding IsHandbrakeAvailable, Converter={StaticResource InverseBoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Handbrake CLI is required for transcoding." VerticalAlignment="Center" Margin="0,0,15,0" Foreground="#ffab00"/>
                                        <Button Content="Download Now" Click="DownloadHandbrake_Click" Style="{StaticResource PrimaryButton}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- API Keys -->
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="API Keys" Style="{StaticResource HeaderBlock}"/>
                                
                                <Grid Margin="0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="OMDb API Key" VerticalAlignment="Center" Foreground="{StaticResource MutedTextColor}"/>
                                    <PasswordBox Grid.Column="1" x:Name="OmdbKeyBox" Background="{StaticResource InputBackground}" Foreground="White" BorderThickness="0" Padding="8" Margin="0,0,10,0" PasswordChanged="OmdbKeyBox_PasswordChanged"/>
                                    <Button Grid.Column="2" Content="Save" Click="SaveOmdb_Click" Padding="15,6"/>
                                </Grid>

                                <Grid Margin="0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="220"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Real-Debrid API Key" VerticalAlignment="Center" Foreground="{StaticResource MutedTextColor}"/>
                                    <TextBox Grid.Column="1" Text="{Binding RealDebridApiKey, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource InputBackground}" Foreground="White" BorderThickness="0" Padding="8" Margin="0,0,10,0"/>
                                    <Button Grid.Column="2" Content="Save" Click="SaveRealDebridKey_Click" Padding="15,6" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="3" Text="{Binding RealDebridKeyStatus}" VerticalAlignment="Center" Foreground="{StaticResource MutedTextColor}" TextWrapping="Wrap"/>
                                </Grid>

                                <Grid Margin="0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="220"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="AllDebrid API Key" VerticalAlignment="Center" Foreground="{StaticResource MutedTextColor}"/>
                                    <TextBox Grid.Column="1" Text="{Binding AllDebridApiKey, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource InputBackground}" Foreground="White" BorderThickness="0" Padding="8" Margin="0,0,10,0"/>
                                    <Button Grid.Column="2" Content="Save" Click="SaveAllDebridKey_Click" Padding="15,6" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="3" Text="{Binding AllDebridKeyStatus}" VerticalAlignment="Center" Foreground="{StaticResource MutedTextColor}" TextWrapping="Wrap"/>
                                </Grid>

                                <Grid Margin="0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="220"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="TorBox API Key" VerticalAlignment="Center" Foreground="{StaticResource MutedTextColor}"/>
                                    <TextBox Grid.Column="1" Text="{Binding TorBoxApiKey, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource InputBackground}" Foreground="White" BorderThickness="0" Padding="8" Margin="0,0,10,0"/>
                                    <Button Grid.Column="2" Content="Save" Click="SaveTorBoxKey_Click" Padding="15,6" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="3" Text="{Binding TorBoxKeyStatus}" VerticalAlignment="Center" Foreground="{StaticResource MutedTextColor}" TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- System Tools -->
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="System Tools" Style="{StaticResource HeaderBlock}"/>
                                <UniformGrid Columns="4" Margin="0,10">
                                    <Button Content="Open Web UI" Click="OpenWebUI_Click" Margin="0,0,10,0"/>
                                    <Button Content="Health Check" Click="ViewHealth_Click" Margin="0,0,10,0"/>
                                    <Button Content="View Logs" Click="ViewRemoteLogs_Click" Margin="0,0,10,0"/>
                                    <Button Content="Restart Pi Service" Click="RestartRemoteService_Click" Background="{StaticResource DangerColor}"/>
                                </UniformGrid>
                                
                                <TextBlock Text="Activity Logs" FontWeight="SemiBold" Margin="0,15,0,10" Foreground="{StaticResource MutedTextColor}"/>
                                <Border Background="#111" CornerRadius="6" Padding="10" Height="150">
                                    <ListBox ItemsSource="{Binding ProcessingLogs}" Background="Transparent" BorderThickness="0" FontSize="11">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Foreground="{StaticResource MutedTextColor}" TextWrapping="Wrap"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                                <Button Content="Open Temp Folder" Click="OpenTempFolder_Click" HorizontalAlignment="Right" Margin="0,10,0,0" Padding="15,4"/>
                            </StackPanel>
                        </Border>
                        
                    </StackPanel>
                </ScrollViewer>
            </Grid>

        </Grid>
    </Grid>
</Window>
