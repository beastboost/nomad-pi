[Unit]
Description=Nomad Pi Server
After=network.target

[Service]
Type=simple
User=pi
# Must run from the repo root: app/main.py uses absolute `from app import ...`
# imports, which don't resolve when the working directory is app/ itself.
WorkingDirectory=/opt/nomad-pi
Environment="PATH=/opt/nomad-pi/venv/bin"
ExecStart=/opt/nomad-pi/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 80 --timeout-keep-alive 300
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
