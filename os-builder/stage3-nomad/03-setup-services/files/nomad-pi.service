[Unit]
Description=Nomad Pi Server
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/nomad-pi/app
Environment="PATH=/opt/nomad-pi/venv/bin"
ExecStart=/opt/nomad-pi/venv/bin/uvicorn main:app --host 0.0.0.0 --port 80
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
